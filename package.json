{
  "author": "Ilio Catallo <info@iliocatallo.it>",
  "name": "parseltongue",
  "version": "0.1.1",
  "description": "S-expression parser",
  "homepage": "https://github.com/iliocatallo/parseltongue#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/iliocatallo/parseltongue.git"
  },
  "keywords": [
    "cell",
    "cons",
    "lisp",
    "parse",
    "parser",
    "s-exp",
    "s-expression",
    "scheme",
    "sexp",
    "sexpression"
  ],
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "node build.js",
    "fmt": "dprint fmt",
    "test": "c8 node --import ./civet.js --test-reporter dot --test src/**/*.test.js",
    "coverage": "c8 report --reporter=lcov"
  },
  "devDependencies": {
    "@danielx/civet": "^0.11.2",
    "@types/node": "^20.10.4",
    "c8": "^10.1.3",
    "dprint": "^0.51.1",
    "esbuild": "^0.27.3",
    "lefthook": "^2.1.1"
  },
  "c8": {
    "include": [ "src" ],
    "exclude": [ "src/.test.*" ],
    "extension": [ ".civet", ".js" ]
  }
}
